# ============================================
# 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制系统
# ============================================

# ============================================
# 应用配置
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://study_user:study_pass@localhost:5432/study_assistant?schema=public

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=study_redis_pass
REDIS_DB=0

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# FTP 文件上传配置
# ============================================
FTP_HOST=localhost
FTP_PORT=21
FTP_USER=study_upload
FTP_PASSWORD=ftp_password
FTP_BASE_URL=http://localhost:2121
UPLOAD_MAX_SIZE=10485760

# ============================================
# AI 服务配置（留空表示不使用）
# ============================================
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 通义千问（阿里云）
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# 智谱 AI
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# 百度文心
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL=ernie-bot-4

# ============================================
# 短信服务配置（可选）
# ============================================
SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_ACCESS_SECRET=
ALIYUN_SMS_SIGN_NAME=小学生复习助手
ALIYUN_SMS_TEMPLATE_CODE=

# ============================================
# 对象存储配置（可选，如使用 OSS/S3）
# ============================================
OSS_PROVIDER=local
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_BASE_URL=

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# 跨域配置
# ============================================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
