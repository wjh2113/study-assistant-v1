# 依赖目录
node_modules/
.pnp/
.pnp.js
.bower/
jspm_packages/

# 构建输出
dist/
build/
.bundle/
.next/
out/
*.tsbuildinfo

# 环境变量（敏感）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!example.env

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 测试覆盖率
coverage/
*.lcov
.nyc_output/

# 临时文件
tmp/
temp/
.uploads/
.cache/
.parcel-cache/

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE 配置
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Prisma（可选：如需同步 migrations 则注释掉）
# prisma/migrations/
prisma/.client/

# 数据库文件（SQLite 等）
*.db
*.sqlite
*.sqlite3

# 上传文件（保留配置，排除实际文件）
backend/uploads/*
!backend/uploads/.gitkeep

# 移动端特定
mobile/.bundle/
mobile/ios/Pods/
mobile/ios/build/
mobile/android/.gradle/
mobile/android/build/
mobile/android/app/build/
mobile/node_modules/

# 前端特定
frontend/.vite/
frontend/dist/

# 后端特定
backend/dist/
backend/coverage/

# 文档生成
docs/generated/
docs/api-generated/

# 质量报告（保留目录，排除临时文件）
docs/quality/*.tmp
docs/quality/*.bak

# Sub-Agent 运行时
sub-agents/*/MEMORY.md
sub-agents/*/.openclaw/

# OpenClaw 运行时
.openclaw/runtime/
.openclaw/cache/

# 敏感配置文件（示例保留，实际内容排除）
backend/src/config/*.key
backend/src/config/*.pem
backend/src/config/*.crt

# 截图和二进制文件（可选）
# docs/screenshots/*.png
# docs/test-reports/*.png
