# AI Phase 2 环境变量配置模板

# ==================== Redis 配置 ====================
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码（如有）
REDIS_PASSWORD=
# Redis 数据库索引（默认）
REDIS_DB=0

# ==================== 监控配置 ====================
# Prometheus 指标导出端口
PROMETHEUS_PORT=9090
# Prometheus 指标路径
PROMETHEUS_PATH=/metrics

# ==================== 缓存配置 ====================
# 默认缓存过期时间（秒）
CACHE_DEFAULT_TTL=3600
# 题目生成缓存时间（秒，24 小时）
CACHE_QUESTION_TTL=86400
# Embedding 缓存时间（秒，7 天）
CACHE_EMBEDDING_TTL=604800
# 对话缓存时间（秒，30 分钟）
CACHE_CHAT_TTL=1800
# 缓存 Redis 数据库索引
CACHE_REDIS_DB=1

# ==================== 批量更新配置 ====================
# 批量更新批次大小
BATCH_UPDATE_SIZE=50
# 最大队列大小
BATCH_MAX_QUEUE=500
# 自动刷新间隔（毫秒）
BATCH_FLUSH_INTERVAL=5000

# ==================== 预算配置 ====================
# 日预算（元）
DAILY_BUDGET=100
# 周预算（元）
WEEKLY_BUDGET=500
# 月预算（元）
MONTHLY_BUDGET=2000
# 成本统计 Redis 数据库索引
COST_REDIS_DB=2

# ==================== 阿里云通义千问配置 ====================
# 阿里云 API Key（推荐）
ALIYUN_API_KEY=your_aliyun_api_key
# 阿里云基础 URL（可选）
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云 Embedding URL（可选）
ALIYUN_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# 兼容旧配置（可选）
AI_API_KEY=
AI_API_URL=

# 各模型独立配置（可选，优先级高于统一配置）
QWEN_FLASH_KEY=
QWEN_FLASH_URL=
QWEN_PLUS_KEY=
QWEN_PLUS_URL=
QWEN_MAX_KEY=
QWEN_MAX_URL=

# ==================== OpenAI 配置 ====================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== Azure OpenAI 配置 ====================
AZURE_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
AZURE_API_KEY=your_azure_api_key
AZURE_DEPLOYMENT=your-deployment-name

# ==================== 月之暗面配置 ====================
MOONSHOT_API_KEY=your_moonshot_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ==================== 百度文心一言配置 ====================
# 百度 API Key（API Key）
BAIDU_API_KEY=your_baidu_api_key
# 百度 Secret Key（Secret Key）
BAIDU_SECRET_KEY=your_baidu_secret_key

# ==================== 讯飞星火配置 ====================
# 讯飞 APP ID
IFLYTEK_APP_ID=your_iflytek_app_id
# 讯飞 API Key
IFLYTEK_API_KEY=your_iflytek_api_key
# 讯飞 API Secret
IFLYTEK_API_SECRET=your_iflytek_api_secret

# ==================== 其他配置 ====================
# 日志级别
LOG_LEVEL=info
# 是否启用监控
ENABLE_MONITORING=true
# 是否启用缓存
ENABLE_CACHE=true
# 是否启用成本分析
ENABLE_COST_ANALYSIS=true
