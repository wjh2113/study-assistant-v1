// Prisma Schema for 小学生全科智能复习助手
// SQLite 兼容版本

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户表
model User {
  id        Int       @id @default(autoincrement())
  username  String?   @unique
  email     String?   @unique
  phone     String?   @unique // 手机号（用于验证码登录）
  password  String?
  role      String    @default("STUDENT") // UserRole: STUDENT, PARENT, TEACHER, ADMIN
  grade     Int?      // 年级 (1-6)
  avatar    String?   // 头像 URL
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // 关联
  exercises       Exercise[]        @relation("StudentExercises")
  wrongQuestions  WrongQuestion[]
  studyPlans      StudyPlan[]
  exerciseRecords ExerciseRecord[]
  familyBindings  FamilyBinding[]   @relation("ParentBindings")
  childBindings   FamilyBinding[]   @relation("ChildBindings")
  textbooks       Textbook[]
  practiceSessions PracticeSession[]
  learningRecords LearningRecord[]
  pointsLedgers   PointsLedger[]

  @@map("users")
}

// 学科表
model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique // 语文、数学、英语等
  grade     Int      // 适用年级
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  knowledgePoints KnowledgePoint[]
  exercises       Exercise[]
  studyPlans      StudyPlan[]

  @@map("subjects")
}

// 知识点表
model KnowledgePoint {
  id          Int      @id @default(autoincrement())
  subjectId   Int
  name        String
  grade       Int      // 所属年级
  description String?
  parentId    Int?     // 父知识点（用于层级结构）
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  subject     Subject          @relation(fields: [subjectId], references: [id])
  parent      KnowledgePoint?  @relation("KnowledgePointHierarchy", fields: [parentId], references: [id])
  children    KnowledgePoint[] @relation("KnowledgePointHierarchy")
  exercises   Exercise[]

  @@map("knowledge_points")
}

// 习题表
model Exercise {
  id              Int          @id @default(autoincrement())
  subjectId       Int
  knowledgePointId Int?
  questionType    String       @default("SINGLE_CHOICE") // QuestionType
  question        String
  options         String?      // JSON 字符串：选择题选项 [{key: "A", value: "选项内容"}]
  answer          String
  explanation     String?
  difficulty      String       @default("MEDIUM") // Difficulty: EASY, MEDIUM, HARD
  grade           Int          // 适用年级
  tags            String       // 逗号分隔的标签
  source          String?
  imageUrl        String?
  videoUrl        String?
  audioUrl        String?
  isPublic        Boolean      @default(true)
  viewCount       Int          @default(0)
  correctRate     Float?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // 关联
  subject        Subject          @relation(fields: [subjectId], references: [id])
  knowledgePoint KnowledgePoint?  @relation(fields: [knowledgePointId], references: [id])
  student        User?            @relation("StudentExercises", fields: [studentId], references: [id])
  studentId      Int?
  wrongQuestions WrongQuestion[]
  exerciseRecords ExerciseRecord[]

  @@map("exercises")
}

// 错题本
model WrongQuestion {
  id         Int      @id @default(autoincrement())
  userId     Int
  exerciseId Int
  wrongAnswer String
  timesWrong Int      @default(1)
  lastWrongAt DateTime @default(now())
  isMastered Boolean @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联
  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
  @@map("wrong_questions")
}

// 学习计划表
model StudyPlan {
  id          Int      @id @default(autoincrement())
  userId      Int
  subjectId   Int?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  dailyGoal   Int      // 每日目标题数
  status      String   @default("ACTIVE") // PlanStatus: ACTIVE, COMPLETED, PAUSED, CANCELLED
  progress    Int      @default(0)
  totalTasks  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  user    User    @relation(fields: [userId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])

  @@map("study_plans")
}

// 学习记录表
model ExerciseRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  exerciseId Int
  isCorrect  Boolean
  userAnswer String
  timeSpent  Int      // 耗时（秒）
  createdAt  DateTime @default(now())

  // 关联
  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@map("exercise_records")
}

// AI 对话记录表
model AiChat {
  id        Int      @id @default(autoincrement())
  userId    Int
  subject   String?
  question  String
  answer    String
  tokens    Int?
  createdAt DateTime @default(now())

  @@map("ai_chats")
}

// 文件上传记录表
model UploadFile {
  id        Int      @id @default(autoincrement())
  userId    Int?
  filename  String
  originalName String
  mimetype  String
  size      Int
  url       String
  ftpPath   String
  createdAt DateTime @default(now())

  @@map("upload_files")
}

// ==================== Sprint 1 新增表 ====================

// 家庭绑定关系表
model FamilyBinding {
  id        Int            @id @default(autoincrement())
  parentId  Int            // 家长 ID
  childId   Int            // 学生 ID
  status    String         @default("PENDING") // BindingStatus: PENDING, ACTIVE, REJECTED, CANCELLED
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // 关联
  parent User @relation("ParentBindings", fields: [parentId], references: [id])
  child  User @relation("ChildBindings", fields: [childId], references: [id])

  @@unique([parentId, childId])
  @@map("family_bindings")
}

// 课本表
model Textbook {
  id          Int      @id @default(autoincrement())
  userId      Int      // 上传者 ID
  title       String   // 课本标题
  subject     String   // 科目
  grade       Int      // 年级
  version     String?  // 版本（人教版、北师大版等）
  coverUrl    String?  // 封面图片
  pdfUrl      String   // PDF 文件 URL
  pdfPath     String   // FTP 路径
  unitTree    String?  // JSON 字符串：单元树结构
  status      String   @default("PENDING") // TextbookStatus: PENDING, PROCESSING, READY, FAILED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  user     User    @relation(fields: [userId], references: [id])
  units    TextbookUnit[]
  practiceSessions PracticeSession[]

  @@map("textbooks")
}

// 课本文单元表
model TextbookUnit {
  id          Int      @id @default(autoincrement())
  textbookId  Int
  parentId    Int?     // 父单元 ID（用于层级结构）
  title       String   // 单元标题
  unitNumber  String?  // 单元编号（如 "Unit 1"）
  pageStart   Int?     // 起始页码
  pageEnd     Int?     // 结束页码
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  textbook Textbook      @relation(fields: [textbookId], references: [id])
  parent   TextbookUnit? @relation("UnitHierarchy", fields: [parentId], references: [id])
  children TextbookUnit[] @relation("UnitHierarchy")
  questions PracticeQuestion[]
  practiceSessions PracticeSession[]

  @@map("textbook_units")
}

// 练习会话表
model PracticeSession {
  id          Int      @id @default(autoincrement())
  userId      Int      // 学生 ID
  textbookId  Int?     // 课本 ID
  unitId      Int?     // 单元 ID
  status      String   @default("ACTIVE") // SessionStatus: ACTIVE, COMPLETED, CANCELLED
  totalQuestions Int   @default(0)
  correctAnswers Int   @default(0)
  score       Int?     // 得分
  timeSpent   Int?     // 耗时（秒）
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  user      User             @relation(fields: [userId], references: [id])
  textbook  Textbook?        @relation(fields: [textbookId], references: [id])
  unit      TextbookUnit?    @relation(fields: [unitId], references: [id])
  questions PracticeQuestion[]
  answers   PracticeAnswer[]

  @@map("practice_sessions")
}

// 练习题目表（会话中的具体题目）
model PracticeQuestion {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  unitId      Int?     // 单元 ID
  questionType String
  question    String
  options     String?  // JSON 字符串：选项
  answer      String
  explanation String?
  userAnswer  String?  // 用户答案
  isCorrect   Boolean? // 是否正确
  score       Int?     // 本题得分
  createdAt   DateTime @default(now())

  // 关联
  session  PracticeSession @relation(fields: [sessionId], references: [id])
  unit     TextbookUnit?   @relation(fields: [unitId], references: [id])
  answers  PracticeAnswer[]

  @@map("practice_questions")
}

// 练习答案表
model PracticeAnswer {
  id        Int      @id @default(autoincrement())
  sessionId Int
  questionId Int
  answer    String
  isCorrect Boolean?
  createdAt DateTime @default(now())

  // 关联
  session  PracticeSession @relation(fields: [sessionId], references: [id])
  question PracticeQuestion @relation(fields: [questionId], references: [id])

  @@map("practice_answers")
}

// 学习记录表（Sprint 1 新版）
model LearningRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  sessionId   Int?     // 练习会话 ID
  textbookId  Int?     // 课本 ID
  unitId      Int?     // 单元 ID
  actionType  String   // 动作类型：START_PRACTICE, FINISH_PRACTICE, VIEW_TEXTBOOK, etc.
  duration    Int?     // 时长（秒）
  score       Int?     // 得分
  metadata    String?  // JSON 字符串：额外数据
  createdAt   DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@map("learning_records")
}

// 积分流水表
model PointsLedger {
  id        Int      @id @default(autoincrement())
  userId    Int
  points    Int      // 积分变化（正数增加，负数减少）
  balance   Int      // 变更后余额
  reason    String   // 积分原因
  referenceId Int?   // 关联记录 ID（如练习会话 ID）
  createdAt DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@map("points_ledgers")
}
