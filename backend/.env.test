# 测试环境配置
NODE_ENV=test
TEST_MODE=true

# 服务器配置
PORT=3001

# JWT 密钥（测试用）
JWT_SECRET=test-jwt-secret-key-for-testing-only

# 数据库配置（测试用 SQLite）
DATABASE_URL=sqlite:./test.db

# Redis 配置（测试用）
REDIS_HOST=localhost
REDIS_PORT=6379

# 队列配置（测试用内存模式）
QUEUE_PROVIDER=memory

# 日志配置
LOG_LEVEL=debug

# AI API 配置（测试 mock）
AI_API_KEY=test-key
AI_API_URL=http://localhost:3001/mock/ai
