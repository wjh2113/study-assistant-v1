# 服务器配置
PORT=3000

# JWT 密钥（生产环境请修改）
JWT_SECRET=your-secret-key-here

# PostgreSQL 数据库连接
DATABASE_URL=postgresql://user:password@localhost:5432/studyass?schema=public

# AI API 配置
AI_API_KEY=your-api-key-here
AI_API_URL=https://api.example.com/v1/chat

# Redis 配置（用于 BullMQ 队列）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 本地文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# 最大文件大小：50MB (52428800 bytes)
