# AI Gateway V2 环境配置示例 (Phase 2)
# 复制此文件为 .env 并根据实际情况修改

# ==================== 服务器配置 ====================
PORT=3000
NODE_ENV=development

# ==================== 数据库配置 ====================
# SQLite 模式（默认）
DATABASE_PATH=./database/sqlite.db

# PostgreSQL 模式（可选）
# DATABASE_URL=postgresql://user:password@localhost:5432/studyass?schema=public

# ==================== Redis 配置 ====================
# 用于限流、Token 计数、缓存和成本分析
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# 缓存专用 Redis DB（可选，默认使用 DB 1）
CACHE_REDIS_DB=1

# 成本分析专用 Redis DB（可选，默认使用 DB 2）
COST_REDIS_DB=2

# ==================== AI 服务商配置 ====================
# 至少配置一个 AI 服务商

# --- 阿里云通义千问（推荐）---
ALIYUN_API_KEY=your_aliyun_api_key_here
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# --- OpenAI（可选）---
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Azure OpenAI（可选）---
# AZURE_API_KEY=your_azure_api_key_here
# AZURE_BASE_URL=https://your-resource.openai.azure.com
# AZURE_DEPLOYMENT=your-deployment-name

# --- 月之暗面（可选）---
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- 百度文心一言（Phase 2 新增）---
# BAIDU_API_KEY=your_baidu_api_key_here
# BAIDU_SECRET_KEY=your_baidu_secret_key_here

# --- 讯飞星火（Phase 2 新增）---
# IFLYTEK_APP_ID=your_iflytek_app_id
# IFLYTEK_API_KEY=your_iflytek_api_key
# IFLYTEK_API_SECRET=your_iflytek_api_secret

# ==================== 缓存配置 (Phase 2) ====================
# 缓存过期时间（秒）
CACHE_DEFAULT_TTL=3600
CACHE_QUESTION_TTL=86400
CACHE_EMBEDDING_TTL=604800
CACHE_CHAT_TTL=1800

# ==================== 批量更新配置 (Phase 2) ====================
BATCH_UPDATE_SIZE=50
BATCH_MAX_QUEUE=500
BATCH_FLUSH_INTERVAL=5000

# ==================== 成本分析配置 (Phase 2) ====================
# 预算配置（单位：元）
DAILY_BUDGET=100
WEEKLY_BUDGET=500
MONTHLY_BUDGET=2000

# ==================== Prometheus 监控配置 (Phase 2) ====================
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:3000

# ==================== 队列配置 ====================
QUEUE_PROVIDER=memory
# 或使用 Redis: QUEUE_PROVIDER=redis

# ==================== 日志配置 ====================
LOG_LEVEL=info

# ==================== JWT 配置 ====================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ==================== 其他配置 ====================
# 请求限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI 生成限流（次/分钟）
AI_GENERATE_LIMIT=20
AI_CHAT_LIMIT=30

# ==================== CDN 配置 (性能优化) ====================
# 是否启用 CDN
CDN_ENABLED=false
# CDN 基础 URL
CDN_URL=https://cdn.example.com
# CDN 服务商：aliyun, tencent, qiniu, cloudflare, generic
CDN_PROVIDER=generic

# 阿里云 OSS 配置
# ALIYUN_OSS_BUCKET=your-bucket
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

# 腾讯云 COS 配置
# TENCENT_COS_BUCKET=your-bucket
# TENCENT_COS_REGION=ap-guangzhou
# TENCENT_COS_SECRET_ID=your-secret-id
# TENCENT_COS_SECRET_KEY=your-secret-key

# 七牛云配置
# QINIU_BUCKET=your-bucket
# QINIU_DOMAIN=your-domain.com
# QINIU_ACCESS_KEY=your-access-key
# QINIU_SECRET_KEY=your-secret-key

# Cloudflare 配置
# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_CDN_URL=https://your-domain.com

# ==================== 性能优化配置 ====================
# 慢请求阈值 (毫秒)
SLOW_REQUEST_THRESHOLD_MS=1000

# 数据库优化
# DB_CACHE_SIZE_MB=64
# DB_MMAP_SIZE_MB=256

# ==================== 前端 CDN 配置 ====================
# VITE_CDN_ENABLED=false
# VITE_CDN_URL=https://cdn.example.com
# VITE_APP_VERSION=1.0.0
