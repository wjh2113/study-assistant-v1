    "bullmq": "^3.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "oss-client": "^2.5.1",
    "pdf-parse": "^2.4.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
