{
  "name": "studyass-backend",
  "version": "1.0.0",
  "description": "学习助手后端服务",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "workers": "node src/workers/index.js",
