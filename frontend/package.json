{
  "name": "study-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "小学生全科智能复习助手",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass",
    "framework": "react"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony": "taro build --type harmony",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony": "npm run build:harmony -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.0.0",
    "@tarojs/helper": "4.0.0",
    "@tarojs/plugin-framework-react": "4.0.0",
    "@tarojs/plugin-platform-alipay": "4.0.0",
    "@tarojs/plugin-platform-h5": "4.0.0",
    "@tarojs/plugin-platform-harmony-hybrid": "4.0.0",
    "@tarojs/plugin-platform-jd": "4.0.0",
    "@tarojs/plugin-platform-qq": "4.0.0",
    "@tarojs/plugin-platform-swan": "4.0.0",
    "@tarojs/plugin-platform-tt": "4.0.0",
    "@tarojs/plugin-platform-weapp": "4.0.0",
    "@tarojs/react": "4.0.0",
    "@tarojs/runtime": "4.0.0",
    "@tarojs/shared": "4.0.0",
    "@tarojs/taro": "4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "mobx": "^6.9.0",
    "mobx-react-lite": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.24.0",
    "@tarojs/cli": "4.0.0",
    "@tarojs/webpack5-runner": "4.0.0",
    "@tarojs/taro-loader": "4.0.0",
    "@types/react": "^18.2.0",
    "@types/webpack": "^5.94.0",
    "@types/node": "^20.11.0",
    "babel-preset-taro": "4.0.0",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "stylelint": "^14.16.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "postcss": "^8.4.0",
    "postcss-import": "^15.1.0",
    "postcss-url": "^10.1.0",
    "sass": "^1.71.0"
  }
}
